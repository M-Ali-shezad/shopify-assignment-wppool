<section class="page-width">
{% if product.available == false %}

  <div class="product-unavailable">
    <p><strong>Currently Unavailable</strong></p>
  </div>

{% else %}

<h2>{{ section.settings.heading }}</h2>
<div class="product-configurator" data-product-id="{{ product.id }}">
  
  <!-- Steps Navigation -->
  <div class="config-steps">
    <button class="step-btn active" data-step="1">Model</button>
    <button class="step-btn" data-step="2">Ventilation</button>
    <button class="step-btn" data-step="3">Molding</button>
    <button class="step-btn" data-step="4">Size Modification</button>
    <button class="step-btn" data-step="5">Order Options</button>
  </div>

  <!-- Step Content -->
  <div class="step-content">

    <!-- STEP 1 -->
    <div class="step-panel active" data-step="1">
      <h3>Model</h3>

      <!-- Color Options -->
      <label>Color Options</label>
      <select name="color_option">
        <option value="">Select Option</option>
        <option value="standard">Standard</option>
        <option value="custom">Custom</option>
      </select>

      <!-- Color -->
      <label>Color</label>
      <select name="color">
        <option value="">Select Color</option>
        <option value="0">White</option>
        <option value="0">Black</option>
      </select>

      <!-- Color Match -->
      <label>Color Match Selection</label>
      <select name="color_match">
        <option value="">Select</option>
        <option value="0">No</option>
        <option value="100">Yes (+100)</option>
      </select>

      <!-- Text Input -->
      <label>Sherwin-Williams Color Code</label>
      <input type="text" name="color_code" placeholder="Enter code">

      <!-- Size -->
      <label>Size</label>
      <select name="size">
        <option value="">Select Size</option>
        <option value="0">30 inch</option>
        <option value="50">36 inch (+50)</option>
      </select>

    </div>

    <!-- STEP 2 -->
    <div class="step-panel" data-step="2">
      <h3>Ventilation</h3>

      <!-- Ventilation Options -->
      <label>Ventilation Options</label>
      <select name="vent_option">
        <option value="">Select</option>
        <option value="0">Standard</option>
        <option value="80">High Power (+80)</option>
      </select>

      <!-- Brand -->
      <label>Brand</label>
      <select name="vent_brand" id="vent-brand">
        <option value="">Select Brand</option>
        <option value="broan">Broan</option>
        <option value="zline">ZLine</option>
      </select>

      <!-- Broan Conditional -->
      <div id="broan-options" style="display:none;">
        <label>CFM</label>
        <select name="broan_cfm" id="broan-cfm">
          <option value="0">Select CFM</option>
          <option value="50">300 CFM (+50)</option>
          <option value="100">600 CFM (+100)</option>
        </select>
      </div>

      <!-- Non Duct Kit -->
      <label>Non-Duct Kit</label>
      <select name="non_duct">
        <option value="0">No</option>
        <option value="60">Yes (+60)</option>
      </select>

      <!-- Recirculating Vent -->
      <label>Add Recirculating Vent</label>
      <select name="recirculating">
        <option value="0">No</option>
        <option value="70">Yes (+70)</option>
      </select>

    </div>

    <!-- STEP 3 -->
    <div class="step-panel" data-step="3">
      <h3>Molding</h3>

      <label>Trim Options</label>
      <select name="trim_option">
        <option value="0">None</option>
        <option value="100">Basic Trim (+100)</option>
      </select>

      <label>How Would You Like Your Trim</label>
      <select name="trim_style">
        <option value="0">Standard</option>
        <option value="120">Custom (+120)</option>
      </select>

      <label>Crown Molding</label>
      <select name="molding">
        <option value="0">None</option>
        <option value="260">Installed (+260)</option>
      </select>

    </div>

    <!-- STEP 4 -->
    <div class="step-panel" data-step="4">
      <h3>Size Modification</h3>

      <label>Increase Depth</label>
      <select name="depth">
        <option value="0">No</option>
        <option value="100">Yes (+100)</option>
      </select>

      <label>Reduce Height</label>
      <select name="height">
        <option value="0">No</option>
        <option value="165">Yes (+165)</option>
      </select>

      <label>Extend Your Chimney</label>
      <select name="chimney">
        <option value="0">No</option>
        <option value="140">Yes (+140)</option>
      </select>

      <label>Add Solid Bottom</label>
      <select name="solid_bottom">
        <option value="0">No</option>
        <option value="110">Yes (+110)</option>
      </select>

    </div>

    <!-- STEP 5 -->
    <div class="step-panel" data-step="5">
      <h3>Order Options</h3>

      <label>Rush Manufacturing</label>
      <select name="rush">
        <option value="0">Standard</option>
        <option value="150">Rush (+150)</option>
      </select>

    </div>

  </div>

  <!-- Price -->
  <div class="config-price">
    Total Price: 
    <span id="total-price" data-base-price="{{ product.price }}">
      {{ product.price | money }}
    </span>
  </div>

  <!-- FORM -->
  <form method="post" action="/cart/add" id="custom-add-to-cart-form" onsubmit="return false;">
  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

  <!-- STEP 1 -->
  <input type="hidden" name="properties[Color Option]" id="prop-color-option">
  <input type="hidden" name="properties[Color]" id="prop-color">
  <input type="hidden" name="properties[Color Match]" id="prop-color-match">
  <input type="hidden" name="properties[Color Code]" id="prop-color-code">
  <input type="hidden" name="properties[Size]" id="prop-size">

  <!-- STEP 2 -->
  <input type="hidden" name="properties[Vent Option]" id="prop-vent-option">
  <input type="hidden" name="properties[Vent Brand]" id="prop-brand">
  <input type="hidden" name="properties[CFM]" id="prop-cfm">
  <input type="hidden" name="properties[Non Duct Kit]" id="prop-non-duct">
  <input type="hidden" name="properties[Recirculating Vent]" id="prop-recirculating">

  <!-- STEP 3 -->
  <input type="hidden" name="properties[Trim Option]" id="prop-trim-option">
  <input type="hidden" name="properties[Trim Style]" id="prop-trim-style">
  <input type="hidden" name="properties[Crown Molding]" id="prop-molding">

  <!-- STEP 4 -->
  <input type="hidden" name="properties[Increase Depth]" id="prop-depth">
  <input type="hidden" name="properties[Reduce Height]" id="prop-height">
  <input type="hidden" name="properties[Extend Chimney]" id="prop-chimney">
  <input type="hidden" name="properties[Solid Bottom]" id="prop-solid-bottom">

  <!-- STEP 5 -->
  <input type="hidden" name="properties[Rush Manufacturing]" id="prop-rush">

  <button type="submit" style="display:none;"></button>
</form>

  <!-- Add to Cart -->
  <button id="add-to-cart-btn" class="shopify-payment-button__button shopify-payment-button__button--unbranded">
    Add to Cart
  </button>

</div>


{% endif %}

{% schema %}
{
  "name": "Product Configurator",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customize Your Product"
    },
    {
      "type": "checkbox",
      "id": "enable_rush",
      "label": "Enable Rush Option",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product Configurator"
    }
  ]
}
{% endschema %}