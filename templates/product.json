{"sections":{"main":{"type":"main-product","blocks":{"vendor":{"type":"text","settings":{"text":"{{ product.vendor }}","text_style":"uppercase"}},"title":{"type":"title","settings":{}},"price":{"type":"price","settings":{}},"variant_picker":{"type":"variant_picker","settings":{"picker_type":"button","swatch_shape":"circle"}},"quantity_selector":{"type":"quantity_selector","disabled":true,"settings":{}},"custom_liquid_LLaQb9":{"type":"custom_liquid","name":"custom product option","settings":{"custom_liquid":"{% if product.tags contains 'custom-product' %}\n<section class=\"page-widths\">\n{% if product.available == false %}\n\n  <div class=\"product-unavailable\">\n    <p><strong>Currently Unavailable<\/strong><\/p>\n  <\/div>\n\n{% else %}\n\n<h2>{{ section.settings.heading }}<\/h2>\n<div class=\"product-configurator\" data-product-id=\"{{ product.id }}\">\n  \n  <!-- Steps Navigation -->\n  <div class=\"config-steps\">\n    <button class=\"step-btn active\" data-step=\"1\">Model<\/button>\n    <button class=\"step-btn\" data-step=\"2\">Ventilation<\/button>\n    <button class=\"step-btn\" data-step=\"3\">Molding<\/button>\n    <button class=\"step-btn\" data-step=\"4\">Size Modification<\/button>\n    <button class=\"step-btn\" data-step=\"5\">Order Options<\/button>\n  <\/div>\n\n  <!-- Step Content -->\n  <div class=\"step-content\">\n\n    <!-- STEP 1 -->\n    <div class=\"step-panel active\" data-step=\"1\">\n      <h3>Model<\/h3>\n\n      <!-- Color Options -->\n      <label>Color Options<\/label>\n      <select name=\"color_option\">\n        <option value=\"\">Select Option<\/option>\n        <option value=\"standard\">Standard<\/option>\n        <option value=\"custom\">Custom<\/option>\n      <\/select>\n\n      <!-- Color -->\n      <label>Color<\/label>\n      <select name=\"color\">\n        <option value=\"\">Select Color<\/option>\n        <option value=\"0\">White<\/option>\n        <option value=\"0\">Black<\/option>\n      <\/select>\n\n      <!-- Color Match -->\n      <label>Color Match Selection<\/label>\n      <select name=\"color_match\">\n        <option value=\"\">Select<\/option>\n        <option value=\"0\">No<\/option>\n        <option value=\"100\">Yes (+100)<\/option>\n      <\/select>\n\n      <!-- Text Input -->\n      <label>Sherwin-Williams Color Code<\/label>\n      <input type=\"text\" name=\"color_code\" placeholder=\"Enter code\">\n\n      <!-- Size -->\n      <label>Size<\/label>\n      <select name=\"size\">\n        <option value=\"\">Select Size<\/option>\n        <option value=\"0\">30 inch<\/option>\n        <option value=\"50\">36 inch (+50)<\/option>\n      <\/select>\n\n    <\/div>\n\n    <!-- STEP 2 -->\n    <div class=\"step-panel\" data-step=\"2\">\n      <h3>Ventilation<\/h3>\n\n      <!-- Ventilation Options -->\n      <label>Ventilation Options<\/label>\n      <select name=\"vent_option\">\n        <option value=\"\">Select<\/option>\n        <option value=\"0\">Standard<\/option>\n        <option value=\"80\">High Power (+80)<\/option>\n      <\/select>\n\n      <!-- Brand -->\n      <label>Brand<\/label>\n      <select name=\"vent_brand\" id=\"vent-brand\">\n        <option value=\"\">Select Brand<\/option>\n        <option value=\"broan\">Broan<\/option>\n        <option value=\"zline\">ZLine<\/option>\n      <\/select>\n\n      <!-- Broan Conditional -->\n      <div id=\"broan-options\" style=\"display:none;\">\n        <label>CFM<\/label>\n        <select name=\"broan_cfm\" id=\"broan-cfm\">\n          <option value=\"0\">Select CFM<\/option>\n          <option value=\"50\">300 CFM (+50)<\/option>\n          <option value=\"100\">600 CFM (+100)<\/option>\n        <\/select>\n      <\/div>\n\n      <!-- Non Duct Kit -->\n      <label>Non-Duct Kit<\/label>\n      <select name=\"non_duct\">\n        <option value=\"0\">No<\/option>\n        <option value=\"60\">Yes (+60)<\/option>\n      <\/select>\n\n      <!-- Recirculating Vent -->\n      <label>Add Recirculating Vent<\/label>\n      <select name=\"recirculating\">\n        <option value=\"0\">No<\/option>\n        <option value=\"70\">Yes (+70)<\/option>\n      <\/select>\n\n    <\/div>\n\n    <!-- STEP 3 -->\n    <div class=\"step-panel\" data-step=\"3\">\n      <h3>Molding<\/h3>\n\n      <label>Trim Options<\/label>\n      <select name=\"trim_option\">\n        <option value=\"0\">None<\/option>\n        <option value=\"100\">Basic Trim (+100)<\/option>\n      <\/select>\n\n      <label>How Would You Like Your Trim<\/label>\n      <select name=\"trim_style\">\n        <option value=\"0\">Standard<\/option>\n        <option value=\"120\">Custom (+120)<\/option>\n      <\/select>\n\n      <label>Crown Molding<\/label>\n      <select name=\"molding\">\n        <option value=\"0\">None<\/option>\n        <option value=\"260\">Installed (+260)<\/option>\n      <\/select>\n\n    <\/div>\n\n    <!-- STEP 4 -->\n    <div class=\"step-panel\" data-step=\"4\">\n      <h3>Size Modification<\/h3>\n\n      <label>Increase Depth<\/label>\n      <select name=\"depth\">\n        <option value=\"0\">No<\/option>\n        <option value=\"100\">Yes (+100)<\/option>\n      <\/select>\n\n      <label>Reduce Height<\/label>\n      <select name=\"height\">\n        <option value=\"0\">No<\/option>\n        <option value=\"165\">Yes (+165)<\/option>\n      <\/select>\n\n      <label>Extend Your Chimney<\/label>\n      <select name=\"chimney\">\n        <option value=\"0\">No<\/option>\n        <option value=\"140\">Yes (+140)<\/option>\n      <\/select>\n\n      <label>Add Solid Bottom<\/label>\n      <select name=\"solid_bottom\">\n        <option value=\"0\">No<\/option>\n        <option value=\"110\">Yes (+110)<\/option>\n      <\/select>\n\n    <\/div>\n\n    <!-- STEP 5 -->\n    <div class=\"step-panel\" data-step=\"5\">\n      <h3>Order Options<\/h3>\n\n      <label>Rush Manufacturing<\/label>\n      <select name=\"rush\">\n        <option value=\"0\">Standard<\/option>\n        <option value=\"150\">Rush (+150)<\/option>\n      <\/select>\n\n    <\/div>\n\n  <\/div>\n\n  <!-- Price -->\n  <div class=\"config-price\">\n    Total Price: \n    <span id=\"total-price\" data-base-price=\"{{ product.price }}\">\n      {{ product.price | money }}\n    <\/span>\n  <\/div>\n\n  <!-- FORM -->\n  <form method=\"post\" action=\"\/cart\/add\" id=\"custom-add-to-cart-form\" onsubmit=\"return false;\">\n  <input type=\"hidden\" name=\"id\" value=\"{{ product.selected_or_first_available_variant.id }}\">\n\n  <!-- STEP 1 -->\n  <input type=\"hidden\" name=\"properties[Color Option]\" id=\"prop-color-option\">\n  <input type=\"hidden\" name=\"properties[Color]\" id=\"prop-color\">\n  <input type=\"hidden\" name=\"properties[Color Match]\" id=\"prop-color-match\">\n  <input type=\"hidden\" name=\"properties[Color Code]\" id=\"prop-color-code\">\n  <input type=\"hidden\" name=\"properties[Size]\" id=\"prop-size\">\n\n  <!-- STEP 2 -->\n  <input type=\"hidden\" name=\"properties[Vent Option]\" id=\"prop-vent-option\">\n  <input type=\"hidden\" name=\"properties[Vent Brand]\" id=\"prop-brand\">\n  <input type=\"hidden\" name=\"properties[CFM]\" id=\"prop-cfm\">\n  <input type=\"hidden\" name=\"properties[Non Duct Kit]\" id=\"prop-non-duct\">\n  <input type=\"hidden\" name=\"properties[Recirculating Vent]\" id=\"prop-recirculating\">\n\n  <!-- STEP 3 -->\n  <input type=\"hidden\" name=\"properties[Trim Option]\" id=\"prop-trim-option\">\n  <input type=\"hidden\" name=\"properties[Trim Style]\" id=\"prop-trim-style\">\n  <input type=\"hidden\" name=\"properties[Crown Molding]\" id=\"prop-molding\">\n\n  <!-- STEP 4 -->\n  <input type=\"hidden\" name=\"properties[Increase Depth]\" id=\"prop-depth\">\n  <input type=\"hidden\" name=\"properties[Reduce Height]\" id=\"prop-height\">\n  <input type=\"hidden\" name=\"properties[Extend Chimney]\" id=\"prop-chimney\">\n  <input type=\"hidden\" name=\"properties[Solid Bottom]\" id=\"prop-solid-bottom\">\n\n  <!-- STEP 5 -->\n  <input type=\"hidden\" name=\"properties[Rush Manufacturing]\" id=\"prop-rush\">\n\n  <button type=\"submit\" style=\"display:none;\"><\/button>\n<\/form>\n  <!-- Add to Cart -->\n  <button id=\"add-to-cart-btn\" class=\"shopify-payment-button__button shopify-payment-button__button--unbranded\">\n    Add to Cart\n  <\/button>\n\n<\/div>\n\n<\/section>\n{% endif %}\n{% endif %}"}},"buy_buttons":{"type":"buy_buttons","settings":{"show_dynamic_checkout":true,"show_gift_card_recipient":true}},"custom_liquid_FRaQ7Q":{"type":"custom_liquid","name":"vimeo video","settings":{"custom_liquid":"{% if product.metafields.custom.vimeo_url != blank %}\n  <div class=\"product-video\">\n    <iframe \n      src=\"https:\/\/player.vimeo.com\/video\/{{ product.metafields.custom.vimeo_url | split: '\/' | last }}\" \n      width=\"100%\" \n      height=\"200px\" \n      frameborder=\"0\" \n      allow=\"autoplay; fullscreen\" \n      allowfullscreen>\n    <\/iframe>\n  <\/div>\n{% endif %}"}},"custom_liquid_XbNbBA":{"type":"custom_liquid","name":"Shipping time","settings":{"custom_liquid":"<p class=\"shipping-time\">\n  {% if settings.enable_quick_ship %}\n    Ships in {{ settings.quick_ship }}\n  {% else %}\n    Ships in {{ settings.standard_ship }}\n  {% endif %}\n<\/p>"}}},"block_order":["vendor","title","price","variant_picker","quantity_selector","custom_liquid_LLaQb9","buy_buttons","custom_liquid_FRaQ7Q","custom_liquid_XbNbBA"],"settings":{"enable_sticky_info":true,"color_scheme":"scheme-1","media_size":"large","constrain_to_viewport":true,"media_fit":"contain","gallery_layout":"stacked","mobile_thumbnails":"hide","media_position":"left","image_zoom":"lightbox","hide_variants":true,"enable_video_looping":false,"padding_top":36,"padding_bottom":12}},"related-products":{"type":"related-products","settings":{"heading":"You may also like","heading_size":"h2","products_to_show":4,"columns_desktop":4,"columns_mobile":"2","color_scheme":"scheme-1","image_ratio":"square","image_shape":"default","show